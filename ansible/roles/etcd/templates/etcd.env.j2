# /etc/default/etcd — managed by no8s-postgres Ansible
# Regenerated on every reconcile run; do not edit manually.

ETCD_NAME="{{ ansible_host }}"
ETCD_DATA_DIR="/var/lib/etcd"
ETCD_LISTEN_PEER_URLS="http://{{ ansible_host }}:2380"
ETCD_LISTEN_CLIENT_URLS="http://{{ ansible_host }}:2379,http://127.0.0.1:2379"
ETCD_INITIAL_ADVERTISE_PEER_URLS="http://{{ ansible_host }}:2380"
ETCD_ADVERTISE_CLIENT_URLS="http://{{ ansible_host }}:2379"

# Build the initial cluster string from all postgres_nodes.
ETCD_INITIAL_CLUSTER="{{ groups['postgres_nodes'] | map('extract', hostvars, 'ansible_host') | map('regex_replace', '^(.+)$', '\\1=http://\\1:2380') | join(',') }}"
ETCD_INITIAL_CLUSTER_STATE="{{ etcd_initial_cluster_state }}"
ETCD_INITIAL_CLUSTER_TOKEN="{{ cluster_name }}-etcd"
